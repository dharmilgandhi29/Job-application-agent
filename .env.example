# Copy this file to .env and fill in your real keys.
# .env is git-ignored and must never be committed. This template is safe to commit.

# Required now — scoring won't run without it.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Not needed yet — added when we build people-search and email features.
APIFY_API_KEY=your_apify_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here